      margin-bottom: 20px;
    }

    .skills {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 15px;
      margin-top: 20px;
    }

    .skill {
      background: white;
      color: #1e3c72;
      padding: 10px 18px;
      border-radius: 30px;
      font-weight: bold;
    }

    .github {
      margin-top: 30px;
    }

    .github a {
      text-decoration: none;
      color: white;
      background: #ff4d6d;
      padding: 12px 24px;
      border-radius: 10px;
      display: inline-block;
      transition: 0.3s;
    }

    .github a:hover {
      background: #ff1e4d;
      transform: scale(1.05);
